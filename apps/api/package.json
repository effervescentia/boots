{
  "name": "@boots/api",
  "type": "module",
  "main": "src/lib.ts",
  "scripts": {
    "build": "bun build ./src/main.ts --outdir ./build --target bun",
    "check:types": "tsc --noEmit",
    "dev": "bun --watch src/main.ts",
    "db:generate": "bunx --bun drizzle-kit generate --config drizzle.config.mts",
    "test": "NODE_ENV=test bun test",
    "test:unit": "glob '**/!(*.it).test.ts' | xargs -- bun run test",
    "test:integration": "glob '**/*.it.test.ts' | xargs -- bun run test",
    "tdd": "bun run test --watch"
  },
  "dependencies": {
    "@bltx/core": "1.6.0",
    "@bltx/db": "1.6.6",
    "@elysiajs/cors": "1.4.0",
    "@elysiajs/cron": "1.4.1",
    "@elysiajs/jwt": "1.4.0",
    "@elysiajs/static": "1.4.7",
    "@passwordless-id/webauthn": "2.3.1",
    "@simplewebauthn/server": "13.2.2",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.45.1",
    "drizzle-typebox": "0.3.3",
    "elysia": "1.4.13",
    "firebase-admin": "13.6.0",
    "human-id": "4.1.2",
    "logixlysia": "6.2.0",
    "parse-duration": "2.1.4",
    "pg": "8.16.3",
    "radashi": "12.7.1",
    "ts-pattern": "5.9.0"
  },
  "devDependencies": {
    "@bltx/test": "1.6.0",
    "@electric-sql/pglite": "0.3.5",
    "@testcontainers/redis": "11.11.0",
    "@types/pg": "8.15.5",
    "@voiceflow/universal-mock": "1.1.0",
    "drizzle-kit": "0.31.8",
    "glob": "11.0.3",
    "jest-date": "1.1.6",
    "rimraf": "6.0.1"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
